{
  "name": "volo",
  "version": "0.1.0",
  "private": true,
  "description": "Volo — AI Life Operating System. One agent, total control.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && python -m uvicorn main:app --reload --port 8000",
    "db:migrate": "cd packages/database && npx drizzle-kit push",
    "db:studio": "cd packages/database && npx drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0"
}
