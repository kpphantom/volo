# ============================================
# VOLO — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
APP_NAME=Volo
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-secret-key
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://volo:volo@localhost:5432/volo
REDIS_URL=redis://localhost:6379

# --- AI Models ---
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Auth ---
JWT_SECRET=change-this-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Integrations (fill as you connect) ---
GITHUB_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# --- X / Twitter OAuth 2.0 ---
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/api/auth/twitter/callback

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_SECRET=

# --- Web3 ---
ETHEREUM_RPC_URL=
SOLANA_RPC_URL=

# --- White Label ---
DEFAULT_TENANT_ID=volo-default
DEFAULT_TENANT_NAME=Volo
