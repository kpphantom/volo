# ============================================
# VOLO — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
APP_NAME=Volo
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://volo:volo@localhost:5432/volo
REDIS_URL=redis://localhost:6379

# --- AI Models ---
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Auth ---
JWT_SECRET=  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Integrations (fill as you connect) ---
GITHUB_TOKEN=

# --- OAuth Providers ---
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Discord: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# X / Twitter: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/api/auth/twitter/callback

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_SECRET=

# --- Web3 ---
ETHEREUM_RPC_URL=
SOLANA_RPC_URL=

# --- White Label ---
DEFAULT_TENANT_ID=volo-default
DEFAULT_TENANT_NAME=Volo
