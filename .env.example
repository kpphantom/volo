# ─────────────────────────────────────────────
# VOLO — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-random-string
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://volo:volo@localhost:5432/volo

# Redis
REDIS_URL=redis://localhost:6379

# ─── AI Models ──────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-20250514

# ─── Auth ───────────────────────────────────
JWT_SECRET=change-me-to-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Integrations ──────────────────────────
# GitHub Personal Access Token
GITHUB_TOKEN=

# Alpaca Trading (paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Gmail / Google APIs
GOOGLE_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Plaid (banking)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Notion
NOTION_API_KEY=

# Linear
LINEAR_API_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ─── Monitoring ────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ─── Storage ───────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Multi-tenant / White Label ────────────
DEFAULT_TENANT_ID=volo-default
DEFAULT_TENANT_NAME=Volo
